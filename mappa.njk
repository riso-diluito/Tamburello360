---
layout: base.njk
title: Mappa delle Squadre
---

<div class="page-header">
    <h1>Mappa</h1>
</div>

<section class="section">
    <div class="container">
        <div class="mappa-container">
            <div id="map"></div>
        </div>

        {%- if collections.teamDatabase.length > 0 -%}
        <div style="margin-top:2rem;">
            <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
                <span style="display:flex;align-items:center;gap:0.4rem;font-family:var(--font-condensed);font-size:0.85rem;font-weight:600;color:var(--gray-600);">
                    <span style="background:#d62828;color:white;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800;">A</span> Serie A
                </span>
            </div>
        </div>
        {%- endif -%}
    </div>
</section>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const map = L.map('map').setView([45.4, 10.4], 8);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
        maxZoom: 18
    }).addTo(map);

    function makeIcon(code, color, logo) {
        const inner = logo
            ? `<img src="${logo}" style="width:32px;height:32px;border-radius:50%;object-fit:cover;">`
            : `<span style="font-weight:800;font-family:'Barlow Condensed',sans-serif;font-size:13px;">${code}</span>`;

        return L.divIcon({
            className: '',
            html: `<div style="background:${color};width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid white;box-shadow:0 3px 12px rgba(0,0,0,0.35);">${inner}</div>`,
            iconSize: [42, 42],
            iconAnchor: [21, 21]
        });
    }

    const squadre = [
        {%- for squadra in collections.teamDatabase -%}
        {
            team_code: {{ squadra.team_code | dump | safe }},
            nome: {{ squadra.name | dump | safe }},
            citta: {{ squadra.city | dump | safe }},
            lat: {{ squadra.lat }},
            lng: {{ squadra.lng }},
            color: {{ squadra.color_primary | dump | safe }},
            logo: {{ squadra.logo | dump | safe }},
            website: {{ squadra.website | dump | safe }},
            description: {{ squadra.description | dump | safe }}
        }{% if not loop.last %},{% endif %}
        {%- endfor -%}
    ];

    squadre.forEach(s => {
        const marker = L.marker([s.lat, s.lng], { icon: makeIcon(s.team_code, s.color || '#d62828', s.logo) }).addTo(map);

        let popup = `<div style="font-family:'Barlow',sans-serif;min-width:190px;">
            <strong style="font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;color:#003049;">${s.nome}</strong>
            <div style="margin-top:0.35rem;font-size:0.82rem;color:#666;">Codice squadra: <strong>${s.team_code}</strong></div>
            <div style="margin-top:0.35rem;font-size:0.85rem;color:#666;">
                📍 ${s.citta}<br>
                🏆 Serie A
            </div>`;
        if (s.description) popup += `<p style="margin-top:0.5rem;font-size:0.82rem;color:#888;">${s.description}</p>`;
        if (s.website) popup += `<a href="${s.website}" target="_blank" style="display:inline-block;margin-top:0.5rem;color:#f77f00;font-weight:700;font-size:0.85rem;">Sito web →</a>`;
        popup += `</div>`;

        marker.bindPopup(popup);
    });
</script>
