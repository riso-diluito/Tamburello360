---
layout: base.njk
title: Classifiche
---

<div class="page-header">
    <h1>Classifiche</h1>
</div>

<section class="section classifiche-page classifiche-page--single" data-mode="outdoor">
    <div class="container">
        <div class="classifiche-controls classifiche-controls--single" aria-label="Controlli classifiche">
            <div class="classifiche-year-switch" aria-label="Seleziona anno">
                <div class="classifiche-year-label">Anno</div>
                <div class="classifiche-year-dropdown">
                    <button
                        class="classifiche-year-trigger"
                        id="classifiche-year-trigger"
                        type="button"
                        aria-haspopup="listbox"
                        aria-expanded="false"
                    >
                        <span id="classifiche-year-current"></span>
                        <span class="classifiche-year-chevron" aria-hidden="true"></span>
                    </button>
                    <div class="classifiche-year-menu" id="classifiche-year-menu" role="listbox" aria-label="Anni disponibili"></div>
                </div>
            </div>
        </div>

        <div class="classifiche-board classifiche-board--single">
            <div class="classifiche-column classifiche-column--a">
                <div class="classifiche-column-header">
                    <span class="classifiche-column-noise" aria-hidden="true"></span>
                    <span class="classifiche-column-orbit" aria-hidden="true"></span>
                    <span class="classifiche-column-slash" aria-hidden="true"></span>
                    <h2>SERIE A</h2>
                </div>
                <div class="classifiche-column-body" id="classifiche-serie-a"></div>
            </div>
        </div>
    </div>
</section>

<script>
    window.classificheData = [
        {%- for classifica in collections.classificheSerieA -%}
        {
            serie: {{ (classifica.data.serie or '') | dump | safe }},
            year: {{ (classifica.data.year or '') | dump | safe }},
            retrocesse: {{ classifica.data.retrocesse or 1 }},
            updated: {{ (classifica.data.updated or '') | dump | safe }},
            teams: [
                {%- for team in classifica.data.teams or [] -%}
                {
                    position: {{ team.position or loop.index }},
                    team_code: {{ (team.team_code or '') | dump | safe }},
                    name: {{ (team.name or '') | dump | safe }},
                    points: {{ team.points or 0 }},
                    wins: {{ team.wins or 0 }},
                    draws: {{ team.draws or 0 }},
                    losses: {{ team.losses or 0 }},
                    played: {{ team.played or 0 }},
                    form: {{ (team.form or team.lastFive or team.last_five or team.recent or '') | dump | safe }}
                }{%- if not loop.last -%},{%- endif -%}
                {%- endfor -%}
            ]
        }{%- if not loop.last -%},{%- endif -%}
        {%- endfor -%}
    ];

    window.teamDatabase = [
        {%- for team in collections.teamDatabase -%}
        {
            team_code: {{ team.team_code | dump | safe }},
            name: {{ team.name | dump | safe }},
            slug: {{ team.slug | dump | safe }},
            logo: {{ team.logo | dump | safe }}
        }{%- if not loop.last -%},{%- endif -%}
        {%- endfor -%}
    ];

    (function () {
        const yearTrigger = document.getElementById('classifiche-year-trigger');
        const yearCurrent = document.getElementById('classifiche-year-current');
        const yearMenu = document.getElementById('classifiche-year-menu');
        const serieAContainer = document.getElementById('classifiche-serie-a');

        const state = {
            year: null,
            yearMenuOpen: false
        };

        const data = Array.isArray(window.classificheData) ? window.classificheData : [];
        const teams = Array.isArray(window.teamDatabase) ? window.teamDatabase : [];
        const teamLookup = teams.reduce((acc, team) => {
            const code = String(team.team_code || '').trim().toUpperCase();
            const slug = normalizeKey(team.slug || '');
            const name = normalizeKey(team.name || '');

            if (code) acc[code] = team;
            if (slug) acc[slug] = team;
            if (name) acc[name] = team;

            return acc;
        }, {});

        const years = Array.from(
            new Set(
                data
                    .map(item => Number(item.year))
                    .filter(year => Number.isFinite(year))
            )
        ).sort((a, b) => b - a);

        state.year = years[0] || new Date().getFullYear();

        if (yearTrigger) {
            yearTrigger.addEventListener('click', () => {
                setYearMenuOpen(!state.yearMenuOpen);
            });
        }

        function normalizeKey(value) {
            return String(value || '')
                .trim()
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function setYearMenuOpen(isOpen) {
            state.yearMenuOpen = isOpen;

            if (yearTrigger) {
                yearTrigger.setAttribute('aria-expanded', String(isOpen));
                yearTrigger.classList.toggle('is-open', isOpen);
            }

            if (yearMenu) {
                yearMenu.classList.toggle('is-open', isOpen);
            }
        }

        function renderYears() {
            if (!yearCurrent || !yearMenu) {
                return;
            }

            if (!years.length) {
                yearCurrent.textContent = 'Nessun anno';
                yearMenu.innerHTML = '<span class="classifiche-year-empty">Nessun anno disponibile</span>';
                return;
            }

            yearCurrent.textContent = String(state.year);
            yearMenu.innerHTML = years.map(year => {
                const isActive = year === state.year;
                return `
                    <button
                        class="classifiche-year-option${isActive ? ' is-active' : ''}"
                        type="button"
                        data-year="${year}"
                        role="option"
                        aria-selected="${isActive}"
                    >
                        ${year}
                    </button>
                `;
            }).join('');

            yearMenu.querySelectorAll('.classifiche-year-option').forEach(button => {
                button.addEventListener('click', () => {
                    const nextYear = Number(button.dataset.year);
                    if (!Number.isFinite(nextYear)) {
                        return;
                    }

                    state.year = nextYear;
                    setYearMenuOpen(false);
                    render();
                });
            });
        }

        function normalizeFormEntry(entry) {
            const value = String(entry || '').trim().toUpperCase();
            if (value === 'W' || value === 'V') return 'W';
            if (value === 'L' || value === 'S') return 'L';
            if (value === 'D' || value === 'P' || value === 'X' || value === 'N') return 'D';
            return 'N';
        }

        function buildFallbackForm(team) {
            const fallback = [];
            const wins = Number(team.wins) || 0;
            const draws = Number(team.draws) || 0;
            const losses = Number(team.losses) || 0;

            for (let i = 0; i < Math.min(wins, 5); i += 1) fallback.push('W');
            for (let i = 0; i < Math.min(draws, 5 - fallback.length); i += 1) fallback.push('D');
            for (let i = 0; i < Math.min(losses, 5 - fallback.length); i += 1) fallback.push('L');
            while (fallback.length < 5) fallback.push('N');

            return fallback.slice(0, 5);
        }

        function getTeamForm(team) {
            if (Array.isArray(team.form) && team.form.length) {
                return team.form.map(normalizeFormEntry).slice(0, 5);
            }

            if (typeof team.form === 'string' && team.form.trim()) {
                const compact = team.form.includes(',') ? team.form.split(',') : team.form.trim().split('');
                return compact.map(normalizeFormEntry).slice(0, 5);
            }

            return buildFallbackForm(team);
        }

        function resolveTeam(team) {
            const code = String(team.team_code || '').trim().toUpperCase();
            const name = normalizeKey(team.name || '');
            return teamLookup[code] || teamLookup[name] || null;
        }

        function renderTeamRow(team, index, totalTeams, retrocesse) {
            const resolvedTeam = resolveTeam(team);
            const teamName = resolvedTeam && resolvedTeam.name ? resolvedTeam.name : (team.name || team.team_code || '?');
            const logo = resolvedTeam && resolvedTeam.logo ? resolvedTeam.logo : '';
            const isPodio = index < 3;
            const relegatedSlots = Number.isFinite(Number(retrocesse)) ? Math.max(Number(retrocesse), 0) : 1;
            const relegationStart = relegatedSlots > 0 ? (totalTeams - relegatedSlots + 1) : totalTeams + 1;
            const isRelegated = index + 1 >= relegationStart;
            const initial = escapeHtml((teamName || '?').trim().charAt(0) || '?');
            const form = getTeamForm(team);
            const logoHtml = logo
                ? `<img class="classifica-team-logo" src="${escapeHtml(logo)}" alt="Logo ${escapeHtml(teamName)}"
                       onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                   <span class="classifica-team-placeholder" style="display:none" aria-hidden="true">${initial}</span>`
                : `<span class="classifica-team-placeholder" aria-hidden="true">${initial}</span>`;

            return `
                <div class="classifica-row${isRelegated ? ' is-relegated' : ''}">
                    <div class="classifica-pos${isPodio ? ' is-top-' + (index + 1) : index === totalTeams - 1 ? ' is-last' : ''}">
                        ${team.position || index + 1}
                    </div>
                    <div class="classifica-team">
                        ${logoHtml}
                        <span class="classifica-team-name">${escapeHtml(teamName)}</span>
                    </div>
                    <div class="classifica-points">${team.points || 0}</div>
                    <div class="classifica-form" aria-label="Ultime cinque partite">
                        ${form.map(result => `
                            <span class="classifica-form-dot is-${result.toLowerCase()}" data-result="${result}"></span>
                        `).join('')}
                    </div>
                </div>
            `;
        }

        function renderClassificaCard(classifica) {
            const teams = Array.isArray(classifica.teams) ? classifica.teams : [];
            const retrocesse = Number(classifica.retrocesse);

            if (!teams.length) {
                return `
                    <article class="classifica-card">
                        <div class="classifica-empty">
                            Nessuna squadra inserita per questa classifica.
                        </div>
                    </article>
                `;
            }

            return `
                <article class="classifica-card">
                    <div class="classifica-card-table" role="table" aria-label="Serie A ${escapeHtml(classifica.year)}">
                        <div class="classifica-head-row" role="row">
                            <span>Pos</span>
                            <span>Squadra</span>
                            <span>Pt</span>
                            <span>Ultime 5</span>
                        </div>
                        <div class="classifica-body">
                            ${teams.map((team, index) => renderTeamRow(team, index, teams.length, retrocesse)).join('')}
                        </div>
                    </div>
                </article>
            `;
        }

        function render() {
            renderYears();
            const filtered = data.filter(item => Number(item.year) === state.year);

            if (!filtered.length) {
                serieAContainer.innerHTML = `
                    <div class="classifica-empty classifica-empty-panel">
                        Nessuna classifica disponibile per Serie A nell'anno ${state.year}.
                    </div>
                `;
                return;
            }

            serieAContainer.innerHTML = filtered.map(renderClassificaCard).join('');
        }

        document.addEventListener('click', event => {
            if (!event.target.closest('.classifiche-year-dropdown')) {
                setYearMenuOpen(false);
            }
        });

        document.addEventListener('keydown', event => {
            if (event.key === 'Escape') {
                setYearMenuOpen(false);
            }
        });

        render();
    }());
</script>
