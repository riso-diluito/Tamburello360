---
layout: base.njk
---
{% set team = name | findTeam(collections.teamDatabase) %}

<style>
    .squadra-storia-page { background: var(--gray-50); }
    
    /* HERO SECTION */
    .squadra-hero {
        background: var(--black);
        color: white;
        padding: clamp(4rem, 10vw, 8rem) 0 4rem;
        position: relative;
        overflow: hidden;
    }
    .squadra-hero-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 2;
    }
    .squadra-hero-logo {
        width: clamp(120px, 15vw, 180px);
        height: auto;
        margin-bottom: 2rem;
        filter: drop-shadow(0 0 20px rgba(255,255,255,0.1));
    }
    .squadra-hero-title {
        font-family: var(--font-display);
        font-size: clamp(4rem, 15vw, 10rem);
        line-height: 0.85;
        text-transform: uppercase;
        margin: 0;
    }
    .squadra-hero-city {
        font-family: var(--font-condensed);
        font-size: clamp(1rem, 2vw, 1.5rem);
        color: var(--orange-light);
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-top: 1rem;
        font-weight: 700;
    }

    /* INFO BAR */
    .info-bar-squadra {
        background: white;
        border-bottom: 1px solid var(--gray-200);
        padding: 1.5rem 0;
        box-shadow: var(--shadow-sm);
    }
    .info-bar-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        text-align: center;
    }
    .info-item label {
        display: block;
        font-family: var(--font-condensed);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--gray-400);
        letter-spacing: 1.5px;
        margin-bottom: 0.25rem;
    }
    .info-item span {
        font-family: var(--font-condensed);
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--navy);
    }

    /* ROSTER SECTION */
    .roster-group { margin-bottom: 4rem; }
    .roster-role-title {
        font-family: var(--font-display);
        font-size: 2.5rem;
        color: var(--navy);
        border-bottom: 4px solid var(--red);
        display: inline-block;
        margin-bottom: 2rem;
    }
    .player-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }
    .player-card {
        background: white;
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .player-number {
        font-family: var(--font-display);
        font-size: 3.5rem;
        color: var(--red);
        opacity: 0.15;
        position: absolute;
        right: 1rem;
        bottom: -0.5rem;
        line-height: 1;
    }
    .player-info h4 {
        font-family: var(--font-condensed);
        font-size: 1.2rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--navy);
        margin: 0;
    }
    .player-bio {
        font-size: 0.85rem;
        color: var(--gray-600);
        margin-top: 0.25rem;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .info-bar-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    }
    @media (max-width: 600px) {
        .info-bar-grid { grid-template-columns: 1fr; }
        .squadra-hero-title { font-size: 4.5rem; }
        .player-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="squadra-storia-page">
    <header class="squadra-hero">
        <div class="container squadra-hero-content">
            {% if team.logo %}<img src="{{ team.logo }}" alt="" class="squadra-hero-logo">{% endif %}
            <h1 class="squadra-hero-title">{{ team.name }}</h1>
            <div class="squadra-hero-city">📍 {{ team.city }}</div>
        </div>
    </header>

    <div class="info-bar-squadra">
        <div class="container info-bar-grid">
            <div class="info-item"><label>Fondazione</label><span>{{ team.foundation_year | default('N/D') }}</span></div>
            <div class="info-item"><label>Sferisterio</label><span>{{ team.city }}</span></div>
            <div class="info-item"><label>Presidente</label><span>{{ team.president | default('N/D') }}</span></div>
            <div class="info-item"><label>Allenatore</label><span>{{ team.coach | default('N/D') }}</span></div>
        </div>
    </div>

    <div class="container mt-3">
        <div class="post-container" style="padding-top: 0;">
            <h2 class="roster-role-title">La Storia</h2>
            {{ content | safe }}
            
            <div class="mt-3">
                {% for role, players in team.roster | groupby("role") %}
                <section class="roster-group">
                    <h2 class="roster-role-title">{{ role }}</h2>
                    <div class="player-grid">
                        {% for player in players %}
                        <div class="player-card">
                            <div class="player-info">
                                <h4>{{ player.name }}</h4>
                                <p class="player-bio">{{ player.bio }}</p>
                            </div>
                            <div class="player-number">{{ player.number }}</div>
                        </div>
                        {% endfor %}
                    </div>
                </section>
                {% endfor %}
            </div>

            <div class="post-footer">
                <a href="/squadre/" class="back-btn">
                    <i class="fas fa-arrow-left"></i> Tutte le Squadre
                </a>
            </div>
        </div>
    </div>
</div>