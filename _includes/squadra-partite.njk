<div class="page-header">
    <h1>Partite {{ team.name }}</h1>
    <p>Tutte le sfide di {{ team.name }} nel match center.</p>
</div>

<section class="section partite-page" data-team="{{ team.slug }}">
    <div class="container">
        <div class="partite-serie-badge-wrap">
            <div class="partite-serie-badge">{{ team.name }}</div>
        </div>

        <div class="partite-round-nav" aria-label="Navigazione giornate {{ team.name }}">
            <button class="partite-round-arrow" id="teamPartitePrevRound" type="button" aria-label="Vai alla giornata precedente">
                <span aria-hidden="true">&lt;</span>
            </button>
            <div class="partite-round-label" id="teamPartiteRoundLabel">GIORNATA 1</div>
            <button class="partite-round-arrow" id="teamPartiteNextRound" type="button" aria-label="Vai alla giornata successiva">
                <span aria-hidden="true">&gt;</span>
            </button>
        </div>

        <div class="partite-list" id="teamPartiteList">
            <div class="empty-state">
                <p>Nessuna partita disponibile per {{ team.name }}.</p>
            </div>
        </div>
    </div>
</section>

<script>
    window.partiteData = {{ collections.partiteEnriched | toPartiteClientData | dump | safe }};

    (function () {
        const teamName = {{ team.name | dump | safe }};
        const list = document.getElementById('teamPartiteList');
        const roundLabel = document.getElementById('teamPartiteRoundLabel');
        const prevButton = document.getElementById('teamPartitePrevRound');
        const nextButton = document.getElementById('teamPartiteNextRound');
        const allMatches = Array.isArray(window.partiteData) ? window.partiteData : [];
        const matches = allMatches.filter(match => match.home_team.name === teamName || match.away_team.name === teamName);
        let renderTimer = null;

        const state = {
            giornata: 1
        };

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function getMaxRound() {
            if (!matches.length) {
                return 1;
            }

            return matches.reduce((maxRound, match) => Math.max(maxRound, Number(match.giornata) || 1), 1);
        }

        function getCurrentRound() {
            const recommended = matches.find(m => m.is_recommended);
            return recommended ? Number(recommended.giornata) : 1;
        }

        function updateRoundNav() {
            const maxRound = getMaxRound();
            roundLabel.textContent = `GIORNATA ${state.giornata}`;
            const hasPrev = state.giornata > 1;
            const hasNext = state.giornata < maxRound;

            prevButton.classList.toggle('is-hidden', !hasPrev);
            prevButton.disabled = !hasPrev;

            nextButton.classList.toggle('is-hidden', !hasNext);
            nextButton.disabled = !hasNext;

            prevButton.setAttribute('aria-label', hasPrev ? `Vai alla giornata ${state.giornata - 1}` : 'Nessuna giornata precedente');
            nextButton.setAttribute('aria-label', hasNext ? `Vai alla giornata ${state.giornata + 1}` : 'Nessuna giornata successiva');
        }

        function renderMatchCard(match) {
            const homeLogo = match.home_team && match.home_team.logo
                ? `<img class="partita-team-logo" src="${escapeHtml(match.home_team.logo)}" alt="Logo ${escapeHtml(match.home_team.name)}">`
                : `<span class="partita-team-logo partita-team-logo--placeholder" aria-hidden="true">${escapeHtml(match.home_team.initial || '?')}</span>`;

            const awayLogo = match.away_team && match.away_team.logo
                ? `<img class="partita-team-logo" src="${escapeHtml(match.away_team.logo)}" alt="Logo ${escapeHtml(match.away_team.name)}">`
                : `<span class="partita-team-logo partita-team-logo--placeholder" aria-hidden="true">${escapeHtml(match.away_team.initial || '?')}</span>`;

            const centerContent = match.is_played
                ? `<div class="partita-score">${escapeHtml(match.score_label)}</div>`
                : `
                    <div class="partita-date-block">
                        <span>${escapeHtml(match.date_day_label || 'Data da definire')}</span>
                        <span>${escapeHtml(match.date_time_label || '--:--')}</span>
                    </div>
                `;

            const mapAction = match.map_url
                ? `<a class="partita-action-link" href="${escapeHtml(match.map_url)}" target="_blank" rel="noreferrer"><span>Dove</span></a>`
                : `<span class="partita-action-link is-disabled" aria-disabled="true"><span>Dove</span></span>`;

            return `
                <article class="partita-card" role="article" aria-label="${escapeHtml(match.home_team.name)} vs ${escapeHtml(match.away_team.name)}" style="background:${escapeHtml(match.gradient)}">
                    <div class="partita-card-main">
                        <div class="partita-team-wrap partita-team-wrap--home">
                            ${homeLogo}
                            <span class="partita-team-name">${escapeHtml(match.home_team.name)}</span>
                        </div>
                        <div class="partita-card-center">
                            ${centerContent}
                        </div>
                        <div class="partita-team-wrap partita-team-wrap--away">
                            <span class="partita-team-name">${escapeHtml(match.away_team.name)}</span>
                            ${awayLogo}
                        </div>
                    </div>
                    <div class="partita-card-divider" aria-hidden="true"></div>
                    <div class="partita-card-actions">
                        <div class="partita-action partita-action--left">
                            ${mapAction}
                        </div>
                        <div class="partita-action partita-action--right">
                            <a class="partita-action-link" href="${escapeHtml(match.info_url)}"><span>Info</span></a>
                        </div>
                    </div>
                </article>
            `;
        }

        function renderEmptyState() {
            list.innerHTML = `
                <div class="empty-state">
                    <p>Nessuna partita inserita per ${escapeHtml(teamName)} alla giornata ${state.giornata}.</p>
                </div>
            `;
        }

        function renderList() {
            const roundMatches = matches.filter(match => Number(match.giornata) === state.giornata);

            list.style.opacity = '0.4';
            list.style.transition = 'opacity 0.18s ease';

            clearTimeout(renderTimer);
            renderTimer = setTimeout(() => {
                if (!roundMatches.length) {
                    renderEmptyState();
                    list.style.opacity = '1';
                    return;
                }

                list.innerHTML = roundMatches.map(renderMatchCard).join('');
                list.style.opacity = '1';
            }, 80);
        }

        function render() {
            const maxRound = getMaxRound();
            state.giornata = Math.min(Math.max(1, state.giornata), maxRound);
            updateRoundNav();
            renderList();
        }

        prevButton.addEventListener('click', () => {
            if (state.giornata <= 1) {
                return;
            }

            state.giornata -= 1;
            render();
        });

        nextButton.addEventListener('click', () => {
            const maxRound = getMaxRound();
            if (state.giornata >= maxRound) {
                return;
            }

            state.giornata += 1;
            render();
        });

        state.giornata = getCurrentRound();
        render();
    }());
</script>
