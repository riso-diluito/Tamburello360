<div class="page-header">
    <h1>Partite {{ team.name }}</h1>
    <p>Archivio completo delle sfide di {{ team.name }}, con accesso rapido alla giornata che ti interessa.</p>
</div>

<section class="section squadra-archive-page" style="--team-accent: {{ team.color_primary }};">
    <div class="container squadra-archive-shell">
        <div class="squadra-archive-head">
            <div>
                <div class="squadra-archive-kicker">{{ team.name }} · {{ team.city }}</div>
                <h2 class="squadra-archive-title">Tutte le Partite</h2>
                <p class="squadra-archive-subtitle">Un archivio diretto e leggibile, pensato per saltare subito alla giornata giusta senza perdere tempo.</p>
            </div>
            <a href="/squadre/{{ team.slug }}/storia/" class="squadra-archive-back">Torna alla storia</a>
        </div>

        <div class="squadra-archive-toolbar" aria-label="Controlli giornata {{ team.name }}">
            <div class="squadra-archive-current">
                <span class="squadra-archive-current-label">Giornata attiva</span>
                <strong id="teamPartiteRoundLabel">1</strong>
            </div>

            <form class="squadra-round-jump" id="teamPartiteRoundForm">
                <label class="squadra-round-jump-label" for="teamPartiteRoundInput">Vai alla giornata</label>
                <div class="squadra-round-jump-controls">
                    <input
                        class="squadra-round-input"
                        id="teamPartiteRoundInput"
                        name="giornata"
                        type="number"
                        inputmode="numeric"
                        min="1"
                        step="1"
                        placeholder="Es. 8"
                    >
                    <button class="squadra-round-button" id="teamPartiteRoundSubmit" type="submit">Mostra</button>
                </div>
            </form>
        </div>

        <div class="squadra-round-chip-list" id="teamPartiteRoundChips" aria-label="Selezione rapida giornate"></div>

        <div class="squadra-archive-list" id="teamPartiteList">
            <div class="empty-state">
                <p>Nessuna partita disponibile per {{ team.name }}.</p>
            </div>
        </div>
    </div>
</section>

<script>
    window.partiteData = {{ collections.partiteEnriched | toPartiteClientData | dump | safe }};

    (function () {
        const teamName = {{ team.name | dump | safe }};
        const list = document.getElementById('teamPartiteList');
        const roundLabel = document.getElementById('teamPartiteRoundLabel');
        const roundInput = document.getElementById('teamPartiteRoundInput');
        const roundForm = document.getElementById('teamPartiteRoundForm');
        const roundChips = document.getElementById('teamPartiteRoundChips');
        const allMatches = Array.isArray(window.partiteData) ? window.partiteData : [];
        const matches = allMatches.filter(match => match.home_team.name === teamName || match.away_team.name === teamName);
        const availableRounds = Array.from(
            new Set(matches.map(match => Number(match.giornata) || 1))
        ).sort((a, b) => a - b);
        let renderTimer = null;

        const state = {
            giornata: 1
        };

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function getMaxRound() {
            if (!availableRounds.length) {
                return 1;
            }

            return availableRounds[availableRounds.length - 1];
        }

        function getCurrentRound() {
            const recommended = matches.find(match => match.is_recommended);
            if (recommended) {
                return Number(recommended.giornata) || 1;
            }

            const playedRounds = matches
                .filter(match => match.is_played)
                .map(match => Number(match.giornata) || 1);

            if (playedRounds.length) {
                return Math.max(...playedRounds);
            }

            return availableRounds[0] || 1;
        }

        function clampRound(value) {
            const requested = Number(value);
            if (!Number.isFinite(requested)) {
                return state.giornata;
            }

            if (availableRounds.includes(requested)) {
                return requested;
            }

            const minRound = availableRounds[0] || 1;
            const maxRound = getMaxRound();
            return Math.min(Math.max(requested, minRound), maxRound);
        }

        function renderRoundChips() {
            if (!roundChips) {
                return;
            }

            roundChips.innerHTML = availableRounds.map(round => `
                <button
                    class="squadra-round-chip${round === state.giornata ? ' is-active' : ''}"
                    type="button"
                    data-round="${round}"
                    aria-pressed="${round === state.giornata ? 'true' : 'false'}"
                >
                    Giornata ${round}
                </button>
            `).join('');

            roundChips.querySelectorAll('.squadra-round-chip').forEach(button => {
                button.addEventListener('click', () => {
                    const requestedRound = Number(button.dataset.round);
                    if (!Number.isFinite(requestedRound)) {
                        return;
                    }

                    state.giornata = requestedRound;
                    render();
                });
            });
        }

        function updateToolbar() {
            roundLabel.textContent = String(state.giornata);

            if (roundInput) {
                roundInput.min = String(availableRounds[0] || 1);
                roundInput.max = String(getMaxRound());
                roundInput.value = String(state.giornata);
            }

            renderRoundChips();
        }

        function buildCenterContent(match) {
            if (match.is_played) {
                return `
                    <div class="squadra-archive-score">${escapeHtml(match.score_label)}</div>
                    <div class="squadra-archive-meta">Finale · ${escapeHtml(match.date_day_label || '')}</div>
                `;
            }

            return `
                <div class="squadra-archive-score squadra-archive-score--scheduled">${escapeHtml(match.date_time_label || '--:--')}</div>
                <div class="squadra-archive-meta">${escapeHtml(match.date_day_label || 'Data da definire')}</div>
            `;
        }

        function renderMatchRow(match) {
            const homeLogo = match.home_team && match.home_team.logo
                ? `<img class="squadra-match-logo" src="${escapeHtml(match.home_team.logo)}" alt="Logo ${escapeHtml(match.home_team.name)}"
                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                   <span class="squadra-match-logo squadra-match-logo--placeholder" style="display:none" aria-hidden="true">${escapeHtml(match.home_team.initial || '?')}</span>`
                : `<span class="squadra-match-logo squadra-match-logo--placeholder" aria-hidden="true">${escapeHtml(match.home_team.initial || '?')}</span>`;

            const awayLogo = match.away_team && match.away_team.logo
                ? `<img class="squadra-match-logo" src="${escapeHtml(match.away_team.logo)}" alt="Logo ${escapeHtml(match.away_team.name)}"
                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                   <span class="squadra-match-logo squadra-match-logo--placeholder" style="display:none" aria-hidden="true">${escapeHtml(match.away_team.initial || '?')}</span>`
                : `<span class="squadra-match-logo squadra-match-logo--placeholder" aria-hidden="true">${escapeHtml(match.away_team.initial || '?')}</span>`;

            return `
                <a
                    href="${escapeHtml(match.info_url)}"
                    class="squadra-match-row squadra-match-row--archive"
                    aria-label="${escapeHtml(match.home_team.name)} contro ${escapeHtml(match.away_team.name)}"
                    style="background:${escapeHtml(match.gradient)}"
                >
                    <div class="squadra-match-home">
                        ${homeLogo}
                        <span class="squadra-match-name">${escapeHtml(match.home_team.name)}</span>
                    </div>
                    <div class="squadra-match-score squadra-match-score--archive">
                        ${buildCenterContent(match)}
                    </div>
                    <div class="squadra-match-away">
                        <span class="squadra-match-name">${escapeHtml(match.away_team.name)}</span>
                        ${awayLogo}
                    </div>
                </a>
            `;
        }

        function renderEmptyState() {
            list.innerHTML = `
                <div class="empty-state">
                    <p>Nessuna partita inserita per ${escapeHtml(teamName)} alla giornata ${state.giornata}.</p>
                </div>
            `;
        }

        function renderList() {
            const roundMatches = matches.filter(match => Number(match.giornata) === state.giornata);

            list.style.opacity = '0.35';
            list.style.transition = 'opacity 0.18s ease';

            clearTimeout(renderTimer);
            renderTimer = setTimeout(() => {
                if (!roundMatches.length) {
                    renderEmptyState();
                    list.style.opacity = '1';
                    return;
                }

                list.innerHTML = roundMatches.map(renderMatchRow).join('');
                list.style.opacity = '1';
            }, 70);
        }

        function render() {
            state.giornata = clampRound(state.giornata);
            updateToolbar();
            renderList();
        }

        if (roundForm) {
            roundForm.addEventListener('submit', (event) => {
                event.preventDefault();
                state.giornata = clampRound(roundInput ? roundInput.value : state.giornata);
                render();
            });
        }

        state.giornata = getCurrentRound();
        render();
    }());
</script>
