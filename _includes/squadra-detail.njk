---
layout: base.njk
---
{% set team = name | findTeam(collections.teamDatabase) %}

<style>
    .squadra-storia-page { background: var(--gray-50); }

    .squadra-hero {
        background: var(--black);
        color: white;
        padding: clamp(4rem, 10vw, 8rem) 0 4rem;
        position: relative;
        overflow: hidden;
    }
    .squadra-hero-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 2;
    }
    .squadra-hero-logo {
        width: clamp(120px, 15vw, 180px);
        height: clamp(120px, 15vw, 180px);
        margin-bottom: 2rem;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.7);
        background: rgba(255,255,255,0.12);
        filter: drop-shadow(0 0 20px rgba(255,255,255,0.1));
    }
    .squadra-hero-logo--placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-family: var(--font-condensed);
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: 0.08em;
    }
    .squadra-hero-title {
        font-family: var(--font-display);
        font-size: clamp(4rem, 15vw, 10rem);
        line-height: 0.85;
        text-transform: uppercase;
        margin: 0;
    }
    .squadra-hero-city {
        font-family: var(--font-condensed);
        font-size: clamp(1rem, 2vw, 1.5rem);
        color: var(--orange-light);
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-top: 1rem;
        font-weight: 700;
    }

    .info-bar-squadra {
        background: white;
        border-bottom: 1px solid var(--gray-200);
        padding: 1.5rem 0;
        box-shadow: var(--shadow-sm);
    }
    .info-bar-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        text-align: center;
    }
    .info-item label {
        display: block;
        font-family: var(--font-condensed);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--gray-400);
        letter-spacing: 1.5px;
        margin-bottom: 0.25rem;
    }
    .info-item span {
        font-family: var(--font-condensed);
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--navy);
    }

    .roster-role-title {
        font-family: var(--font-display);
        font-size: 2.5rem;
        color: var(--navy);
        border-bottom: 4px solid var(--red);
        display: inline-block;
        margin-bottom: 2rem;
    }

    @media (max-width: 900px) {
        .info-bar-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    }
    @media (max-width: 600px) {
        .info-bar-grid { grid-template-columns: 1fr; }
        .squadra-hero-title { font-size: 4.5rem; }
    }
</style>

<div class="squadra-storia-page">
    <header class="squadra-hero">
        <div class="container squadra-hero-content">
            {%- if team.logo -%}
            <img src="{{ team.logo }}" alt="{{ team.name }}" class="squadra-hero-logo"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="squadra-hero-logo squadra-hero-logo--placeholder" style="display:none">{{ team.initial }}</div>
            {%- else -%}
            <div class="squadra-hero-logo squadra-hero-logo--placeholder">{{ team.initial }}</div>
            {%- endif -%}
            <h1 class="squadra-hero-title">{{ team.name }}</h1>
            <div class="squadra-hero-city">{{ team.city }}</div>
        </div>
    </header>

    <div class="info-bar-squadra">
        <div class="container info-bar-grid">
            <div class="info-item"><label>Fondazione</label><span>{{ team.foundation_year | default('N/D') }}</span></div>
            <div class="info-item"><label>Sferisterio</label><span>{{ team.city }}</span></div>
            <div class="info-item"><label>Presidente</label><span>{{ team.president | default('N/D') }}</span></div>
            <div class="info-item"><label>Allenatore</label><span>{{ team.coach | default('N/D') }}</span></div>
        </div>
    </div>

    <div class="container mt-3">
        <div class="post-container" style="padding-top: 0;">
            <h2 class="roster-role-title">La Storia</h2>
            {{ content | safe }}
            {% set squadraPartite = collections.partitePerSquadra[team.slug] %}
            {% set partiteGiocate = squadraPartite | playedMatches %}
            {% if partiteGiocate and partiteGiocate.length > 0 %}
            <div class="squadra-recent-matches">
                <h2 class="roster-role-title">Ultime Partite</h2>
                <div class="squadra-matches-list">
                    {% for partita in partiteGiocate | reverse | limit(5) %}
                    <a href="{{ partita.info_url }}" class="squadra-match-row" style="background: {{ partita.gradient }}">
                        <div class="squadra-match-home">
                            {%- if partita.home_team.logo -%}
                            <img src="{{ partita.home_team.logo }}" alt="{{ partita.home_team.name }}"
                                 class="squadra-match-logo"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <span class="squadra-match-logo squadra-match-logo--placeholder" style="display:none">{{ partita.home_team.initial }}</span>
                            {%- else -%}
                            <span class="squadra-match-logo squadra-match-logo--placeholder">{{ partita.home_team.initial }}</span>
                            {%- endif -%}
                            <span class="squadra-match-name">{{ partita.home_team.name }}</span>
                        </div>
                        <div class="squadra-match-score">{{ partita.score_label }}</div>
                        <div class="squadra-match-away">
                            <span class="squadra-match-name">{{ partita.away_team.name }}</span>
                            {%- if partita.away_team.logo -%}
                            <img src="{{ partita.away_team.logo }}" alt="{{ partita.away_team.name }}"
                                 class="squadra-match-logo"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <span class="squadra-match-logo squadra-match-logo--placeholder" style="display:none">{{ partita.away_team.initial }}</span>
                            {%- else -%}
                            <span class="squadra-match-logo squadra-match-logo--placeholder">{{ partita.away_team.initial }}</span>
                            {%- endif -%}
                        </div>
                    </a>
                    {% endfor %}
                </div>
                <a href="/squadre/{{ team.slug }}/partite/" class="btn btn-outline btn-squadra-partite">
                    Tutte le partite &rarr;
                </a>
            </div>
            {% endif %}
            <div class="post-footer">
                <a href="/squadre/" class="back-btn">&larr; Tutte le Squadre</a>
            </div>
        </div>
    </div>
</div>
